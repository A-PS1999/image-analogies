{
    "version": 8,
    "configurePresets": [
        {
            "name": "basic-preset",
            "displayName": "g++ 13.4.0 x86_64-pc-cygwin",
            "description": "Using compilers: C++ = C:\\cygwin64\\bin\\g++.exe",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}