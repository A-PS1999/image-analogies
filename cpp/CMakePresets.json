{
    "version": 8,
    "configurePresets": [
        {
            "name": "basic-preset",
            "displayName": "g++ 16.1.0 x86_64-MSYS2",
            "description": "Using compilers: C++ = C:\\msys64\\ucrt64\\bin\\g++.exe",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}